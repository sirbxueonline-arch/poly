# ─────────────────────────────────────────────────────────────────────────
# Polymarket Pulse — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and will NEVER be committed.
#
# DO NOT commit real keys to source control. The OpenAI service auto-detects
# keys in public commits and revokes them.
# ─────────────────────────────────────────────────────────────────────────

# OpenAI — used by the server-side digest job to produce AI verdicts.
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-replace-me

# No database needed. Predictions live in server-process memory and are
# regenerated by the refresh job every 5 minutes.
